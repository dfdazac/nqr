{% raw %}
PREFIX ex: <http://example.org/>
{% endraw %}

{% set select_line = '(COUNT(*) AS ?n)' if count else '?x' %}
SELECT {{ select_line }}
{% for split in splits %}
FROM ex:{{ split }}
{% endfor %}
WHERE {
    ex:Q{{ flat_ids[0] }} ex:P{{ flat_ids[1] }} ?x .
    ex:Q{{ flat_ids[2] }} ex:P{{ flat_ids[3] }} ?x .
    ex:Q{{ flat_ids[4] }} ex:P{{ flat_ids[5] }} ?x .
}
