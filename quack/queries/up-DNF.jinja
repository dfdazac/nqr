PREFIX ex: <http://example.org/>

SELECT ?x ?y
{% for split in splits %}
FROM ex:{{ split }}
{% endfor %}
WHERE {
    {
        ex:Q{{ flat_ids[0] }} ex:P{{ flat_ids[1] }} ?x .
        ?x ex:P{{ flat_ids[5] }} ?y .
    } UNION {
        ex:Q{{ flat_ids[2] }} ex:P{{ flat_ids[3] }} ?x .
        ?x ex:P{{ flat_ids[5] }} ?y .
    }
}