PREFIX ex: <http://example.org/>

SELECT ?x
{% for split in splits %}
FROM ex:{{ split }}
{% endfor %}
WHERE {
    ex:Q{{ flat_ids[0] }} ex:P{{ flat_ids[1] }} ?x .
    ex:Q{{ flat_ids[2] }} ex:P{{ flat_ids[3] }} ?x .
    FILTER NOT EXISTS {
        ex:Q{{ flat_ids[4] }} ex:P{{ flat_ids[5] }} ?x .
    }
}
