{% raw %}
PREFIX ex: <http://example.org/>
{% endraw %}

SELECT ?x ?y
{% for split in splits %}
FROM ex:{{ split }}
{% endfor %}
WHERE {
    ex:Q{{ flat_ids[0] }} ex:P{{ flat_ids[1] }} ?x .
    FILTER NOT EXISTS {
        ?x ex:P{{ flat_ids[2] }} ?y .
    }
    ex:Q{{ flat_ids[4] }} ex:P{{ flat_ids[5] }} ?y .
}
